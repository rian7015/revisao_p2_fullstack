<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <title>Resposta Cadastro</title>
  <link rel="stylesheet" href="estilo.css">
</head>
<body>

  <header>
    <h1>✅ Resposta do Servidor (GET)</h1>
    <nav>
      <a href="home.html">← Voltar</a>
    </nav>
  </header>

  <main>
    <section>
      <h2>Dados recebidos via GET:</h2>

      <p><strong>Nome:</strong> <%= nome %></p>
      <p><strong>Sobrenome:</strong> <%= sobrenome %></p>
      <p><strong>Nascimento:</strong> <%= nascimento %></p>
      <p><strong>Estado Civil:</strong> <%= civil %></p>

      <% if (nome && nome.length > 0) { %>
        <p style="color: green;">✅ Nome preenchido!</p>
      <% } else { %>
        <p style="color: red;">⚠️ Nome não foi preenchido.</p>
      <% } %>
    </section>
  </main>

</body>
</html>
